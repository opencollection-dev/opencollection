{
  "name": "opencollection",
  "private": true,
  "workspaces": [
    "packages/oc-converters",
    "packages/oc-docs",
    "packages/oc-schema",
    "packages/oc-schema-explorer",
    "packages/oc-spec",
    "packages/oc-spec-site",
    "packages/oc-types"
  ],
  "homepage": "https://www.opencollection.com",
  "scripts": {
    "prepare": "husky",
    "run:docs": "npm run dev -w @opencollection/docs",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test:run --workspaces --if-present"
  },
  "lint-staged": {
    "packages/oc-docs/**/*.{ts,tsx}": "eslint --config packages/oc-docs/eslint.config.js --max-warnings 0 --report-unused-disable-directives --fix",
    "packages/oc-docs/**/*.{json,css,scss,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  }
}
